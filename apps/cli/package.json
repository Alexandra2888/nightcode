{
  "name": "cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "nightcode": "src/index.tsx"
  },
  "scripts": {
    "dev": "bun --watch run src/index.tsx",
    "start": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun --external '@opentui/*'"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": ">=19.0.0"
  }
}

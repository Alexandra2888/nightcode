// Prisma schema for nightcode's conversation store.
//
// Two models: a `Session` (a conversation container) owns many `Message` rows.
// A session is scoped to a Clerk `userId` (a plain string — user records live in
// Clerk, so there's no users table here). A message reaches the user only via its
// parent session. A message mirrors the AI SDK `UIMessage`
// (id + role + parts + optional metadata); `parts` and `metadata` are stored as
// `Json` verbatim rather than normalized, because the AI SDK owns and evolves
// the shape of `parts` — the same reason `routes/chat/schema.ts` validates via
// the SDK's `safeValidateUIMessages` instead of a hand-written Zod tree.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

enum Role {
  system
  user
  assistant
}

// The behaviour mode a turn ran in. Lowercase members mirror the `Role`
// convention above and match the CLI's `ModeName` union (`nightcode-ai`), so the
// generated `Mode` type re-exported from `nightcode-database` is the single
// source of truth both sides `satisfies` against.
enum Mode {
  build
  plan
}

model Session {
  id        String   @id @default(cuid())
  // Clerk user id — every session belongs to exactly one signed-in user. Indexed
  // because the session list and every ownership check filter on it.
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]

  @@index([userId])
  @@map("sessions")
}

model Message {
  // Reuse the client-generated UIMessage.id so re-writing the same message is an
  // idempotent upsert rather than a duplicate insert.
  id        String   @id
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      Role
  parts     Json // UIMessage.parts, stored verbatim
  metadata  Json? // UIMessage.metadata (optional)
  mode      Mode // the mode this turn was sent in — drives the message's left-bar color
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("messages")
}

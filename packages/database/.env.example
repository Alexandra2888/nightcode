# Direct TCP connection string for Prisma Postgres (from the Prisma dashboard).
# The pg driver adapter needs the direct `postgres://…@db.prisma.io` URL — NOT
# the `prisma+postgres://` Accelerate URL. Copy this file to `.env` and fill in.
DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
